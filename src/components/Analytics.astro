---
import { GA_MEASUREMENT_ID } from '../config/analytics';

const gaMeasurementId = GA_MEASUREMENT_ID;
---

{gaMeasurementId && <meta name="pg-ga-measurement-id" content={gaMeasurementId} />}

{
  gaMeasurementId && (
    <script>
      import {
        ATTRIBUTION_SENT_KEY,
        ATTRIBUTION_STORAGE_KEY,
        captureAttribution,
        getAnalyticsPageLocation,
        getAnalyticsReferrer,
        sanitizeEvent,
      } from '../lib/attribution.mjs';

      const measurementId = document.querySelector('meta[name="pg-ga-measurement-id"]')?.getAttribute('content') || '';
      const consentKey = 'pg_analytics_consent';
      let analyticsLoaded = false;
      let eventQueue: Array<{ name: string; parameters: Record<string, string | number> }> = [];

      const readSessionValue = (key: string) => {
        try {
          return sessionStorage.getItem(key);
        } catch {
          return null;
        }
      };

      const writeSessionValue = (key: string, value: string) => {
        try {
          sessionStorage.setItem(key, value);
        } catch {
          // Storage can be unavailable in hardened browsers. Attribution then
          // remains page-scoped rather than inventing a persistent identity.
        }
      };

      const getConsent = () => {
        try {
          return localStorage.getItem(consentKey);
        } catch {
          return null;
        }
      };

      let storedAttribution = null;
      try {
        const value = readSessionValue(ATTRIBUTION_STORAGE_KEY);
        storedAttribution = value ? JSON.parse(value) : null;
      } catch {
        storedAttribution = null;
      }

      const attribution = captureAttribution({
        pageUrl: window.location.href,
        referrer: document.referrer,
        siteOrigin: window.location.origin,
        stored: storedAttribution,
      });
      writeSessionValue(ATTRIBUTION_STORAGE_KEY, JSON.stringify(attribution));

      const send = (payload: { name: string; parameters: Record<string, string | number> }) => {
        const gtag = (window as any).gtag;
        if (!analyticsLoaded || getConsent() !== 'accepted' || typeof gtag !== 'function') return;
        gtag('event', payload.name, payload.parameters);
      };

      (window as any).pgTrack = (name: string, parameters: Record<string, unknown> = {}) => {
        const payload = sanitizeEvent(name, parameters, attribution);
        if (!payload || getConsent() === 'declined') return;

        if (getConsent() === 'accepted' && analyticsLoaded) {
          send(payload);
          return;
        }

        // Hold only anonymous, allow-listed values in memory while the visitor
        // decides. Nothing leaves the browser until consent is accepted.
        eventQueue.push(payload);
      };

      const sendSessionAttribution = () => {
        if (readSessionValue(ATTRIBUTION_SENT_KEY) === 'true') return;
        (window as any).pgTrack('session_attribution', {});
        writeSessionValue(ATTRIBUTION_SENT_KEY, 'true');
      };

      const loadAnalytics = () => {
        if (analyticsLoaded || getConsent() !== 'accepted' || !measurementId) return;
        analyticsLoaded = true;
        (window as any)[`ga-disable-${measurementId}`] = false;
        (window as any).dataLayer = (window as any).dataLayer || [];
        (window as any).gtag = (window as any).gtag || function () { (window as any).dataLayer.push(arguments); };
        const gtag = (window as any).gtag;

        gtag('consent', 'default', {
          analytics_storage: 'granted',
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
        });
        gtag('js', new Date());
        gtag('config', measurementId, {
          allow_google_signals: false,
          allow_ad_personalization_signals: false,
          cookie_flags: 'SameSite=Lax;Secure',
          page_location: getAnalyticsPageLocation({
            siteOrigin: window.location.origin,
            path: window.location.pathname,
            attribution,
          }),
          page_referrer: getAnalyticsReferrer(attribution),
        });

        const script = document.createElement('script');
        script.async = true;
        script.src = `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(measurementId)}`;
        document.head.appendChild(script);

        const queued = eventQueue;
        eventQueue = [];
        queued.forEach(send);
        sendSessionAttribution();
      };

      const disableAnalytics = () => {
        eventQueue = [];
        (window as any)[`ga-disable-${measurementId}`] = true;
        const gtag = (window as any).gtag;
        if (typeof gtag === 'function') gtag('consent', 'update', { analytics_storage: 'denied' });
        document.cookie.split(';').forEach((cookie) => {
          const name = cookie.split('=')[0]?.trim();
          if (name?.startsWith('_ga')) {
            document.cookie = `${name}=; Max-Age=0; path=/; SameSite=Lax; Secure`;
          }
        });
      };

      window.addEventListener('pg:analytics-consent', (event) => {
        if ((event as CustomEvent).detail === 'accepted') loadAnalytics();
        if ((event as CustomEvent).detail === 'declined') disableAnalytics();
      });

      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest<HTMLElement>('a, button') : null;
        if (!target) return;

        const contentPath = window.location.pathname;
        const placement = target.dataset.analyticsPlacement || 'unspecified';

        if (target.matches('[data-profile-cta]')) {
          (window as any).pgTrack('profile_cta_click', {
            content_path: contentPath,
            cta_type: target.dataset.profileCta || 'unknown',
            placement,
          });
        }

        if (target.matches('[data-contact-method]') || (target instanceof HTMLAnchorElement && target.protocol === 'mailto:')) {
          (window as any).pgTrack('contact_intent', {
            contact_method: target.dataset.contactMethod || 'email',
            content_path: contentPath,
            placement,
          });
        }

        if (target.matches('[data-newsletter-cta]')) {
          (window as any).pgTrack('newsletter_cta_click', {
            content_path: contentPath,
            placement,
          });
        }

        if (target.matches('[data-related-post]')) {
          (window as any).pgTrack('related_post_click', {
            content_path: contentPath,
            related_path: target.getAttribute('href') || '',
            placement,
          });
        }

        if (target.matches('[data-share-method]')) {
          (window as any).pgTrack('share_click', {
            content_path: contentPath,
            share_method: target.dataset.shareMethod || 'unknown',
            placement,
          });
        }

        if (target instanceof HTMLAnchorElement && target.protocol.startsWith('http')) {
          const destination = new URL(target.href, window.location.href);
          if (destination.origin !== window.location.origin) {
            (window as any).pgTrack('outbound_click', {
              content_path: contentPath,
              destination_host: destination.hostname,
              destination_type: target.dataset.profileCta || 'external',
              placement,
            });
          }
        }
      });

      const observeNewsletterPrompts = () => {
        const elements = document.querySelectorAll('[data-newsletter-impression]');
        if (!('IntersectionObserver' in window)) return;

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting || entry.intersectionRatio < 0.5) return;
            (window as any).pgTrack('newsletter_cta_view', {
              content_path: window.location.pathname,
              placement: entry.target.getAttribute('data-analytics-placement') || 'unspecified',
            });
            observer.unobserve(entry.target);
          });
        }, { threshold: 0.5 });

        elements.forEach((element) => observer.observe(element));
      };

      if (getConsent() === 'accepted') loadAnalytics();
      observeNewsletterPrompts();
    </script>
  )
}
