---
import { PROFILE } from '../data/profile';
---

<section class="hero-gradient max-w-5xl mx-auto px-6 py-24 md:py-36 relative">
  <div class="relative z-10">
    <p class="text-(--color-primary) font-semibold mb-4 animate-fade-up text-sm tracking-widest uppercase">{PROFILE.headline}</p>
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 animate-fade-up stagger-1">
      <span class="gradient-text">Pete Ghiorse</span>
    </h1>
    <p class="text-xl md:text-2xl text-slate-500 dark:text-slate-400 max-w-2xl mb-4 leading-relaxed animate-fade-up stagger-2">
      I build AI products, test how they behave with real users and mutable data, and publish what the failures teach.
    </p>
    <p class="text-lg text-slate-500 dark:text-slate-400 max-w-xl mb-10 leading-relaxed animate-fade-up stagger-3">
      I’m a <strong class="text-slate-900 dark:text-white font-medium">Group Product Manager for AI/ML</strong> at Capital One and the founder of
      <strong class="text-slate-900 dark:text-white font-medium">Honeydew</strong>, a real family-coordination product I use as a lab for agent behavior, evaluation, and trust.
    </p>
    <div class="flex flex-wrap gap-4 animate-fade-up stagger-4">
      <a
        href="/resume"
        data-profile-cta="recruiter_snapshot"
        data-analytics-placement="homepage_hero"
        class="group px-7 py-3.5 bg-(--color-primary) text-white rounded-xl font-medium hover:bg-(--color-primary-dark) transition-all shadow-lg shadow-blue-500/25 hover:shadow-blue-500/40 hover:-translate-y-0.5"
      >
        Recruiter snapshot
        <span class="inline-block ml-1 transition-transform group-hover:translate-x-0.5">&rarr;</span>
      </a>
      <a
        href="/projects"
        data-profile-cta="selected_work"
        data-analytics-placement="homepage_hero"
        class="px-7 py-3.5 border border-slate-200 dark:border-slate-700 rounded-xl font-medium hover:bg-slate-50 dark:hover:bg-slate-800 hover:border-(--color-primary)/30 transition-all hover:-translate-y-0.5"
      >
        Explore the evidence
      </a>
      <a href="/contact" data-profile-cta="recruiter_contact" data-analytics-placement="homepage_hero" class="px-3 py-3.5 text-(--color-primary) font-semibold hover:underline">
        Discuss an AI product role &rarr;
      </a>
    </div>
  </div>
</section>
