---
interface Props {
  company: string;
  role: string;
  period: string;
  description: string;
  highlights?: string[];
}

const { company, role, period, description, highlights = [] } = Astro.props;
---

<div class="relative pl-8 pb-12 border-l-2 border-slate-200 dark:border-slate-800 last:pb-0 group">
  <div class="absolute left-[-9px] top-1 w-4 h-4 rounded-full bg-(--color-primary) border-4 border-white dark:border-[#0a0f1a] transition-transform group-hover:scale-125"></div>
  <div class="mb-1 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
    <h3 class="font-bold text-lg">{role}</h3>
    <span class="text-xs font-medium text-slate-500 dark:text-slate-400 bg-slate-50 dark:bg-slate-800 px-3 py-1 rounded-full border border-slate-200 dark:border-slate-700">{period}</span>
  </div>
  <p class="text-(--color-primary) font-semibold text-sm mb-3">{company}</p>
  {description && <p class="text-slate-500 dark:text-slate-400 leading-relaxed mb-3 text-sm">{description}</p>}
  {highlights.length > 0 && (
    <ul class="space-y-1.5">
      {highlights.map(h => (
        <li class="flex items-start gap-2 text-sm text-slate-500 dark:text-slate-400">
          <span class="text-(--color-primary) mt-0.5 shrink-0">&#x2022;</span>
          <span>{h}</span>
        </li>
      ))}
    </ul>
  )}
</div>
