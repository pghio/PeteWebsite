---
interface Props {
  eyebrow: string;
  title: string;
  summary: string;
  role: string;
  method: string;
  outcome: string;
  evidenceHref: string;
  evidenceLabel?: string;
  repoHref?: string;
  status?: string;
}

const {
  eyebrow,
  title,
  summary,
  role,
  method,
  outcome,
  evidenceHref,
  evidenceLabel = 'Inspect the evidence',
  repoHref,
  status,
} = Astro.props;
const evidenceIsExternal = evidenceHref.startsWith('http');
---

<article class="p-7 rounded-2xl bg-slate-50 dark:bg-[#141b2d] border border-slate-200 dark:border-slate-800">
  <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
    <p class="text-xs font-semibold text-(--color-primary) tracking-widest uppercase">{eyebrow}</p>
    {status && <span class="text-xs text-slate-500 dark:text-slate-400">{status}</span>}
  </div>
  <h3 class="text-2xl font-bold mb-3">{title}</h3>
  <p class="text-slate-500 dark:text-slate-400 leading-relaxed mb-6">{summary}</p>
  <dl class="space-y-4 text-sm mb-6">
    <div>
      <dt class="font-bold text-slate-900 dark:text-white">My role</dt>
      <dd class="text-slate-500 dark:text-slate-400 mt-1 leading-relaxed">{role}</dd>
    </div>
    <div>
      <dt class="font-bold text-slate-900 dark:text-white">How I worked</dt>
      <dd class="text-slate-500 dark:text-slate-400 mt-1 leading-relaxed">{method}</dd>
    </div>
    <div>
      <dt class="font-bold text-slate-900 dark:text-white">What changed</dt>
      <dd class="text-slate-500 dark:text-slate-400 mt-1 leading-relaxed">{outcome}</dd>
    </div>
  </dl>
  <div class="flex flex-wrap gap-5 text-sm font-semibold">
    <a href={evidenceHref} target={evidenceIsExternal ? '_blank' : undefined} rel={evidenceIsExternal ? 'noopener' : undefined} data-profile-cta="case_study" data-analytics-placement="selected_work" class="text-(--color-primary) hover:underline">{evidenceLabel} &rarr;</a>
    {repoHref && <a href={repoHref} target="_blank" rel="noopener" data-profile-cta="research_repo" data-analytics-placement="selected_work" class="text-(--color-primary) hover:underline">View repository &rarr;</a>}
  </div>
</article>
