---
interface Props {
  title: string;
  description: string;
  tags: string[];
  link?: string;
  status?: string;
}

const { title, description, tags, link, status } = Astro.props;
---

<div class="card-hover border border-slate-200 dark:border-slate-800 rounded-2xl p-6 bg-white dark:bg-[#141b2d] group">
  <div class="flex items-start justify-between mb-3">
    <h3 class="text-lg font-bold group-hover:text-(--color-primary) transition-colors">{title}</h3>
    {status && (
      <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-blue-50 dark:bg-blue-900/30 text-(--color-primary) whitespace-nowrap">
        {status}
      </span>
    )}
  </div>
  <p class="text-slate-500 dark:text-slate-400 mb-5 leading-relaxed text-sm">{description}</p>
  <div class="flex flex-wrap gap-2 mb-5">
    {tags.map(tag => (
      <span class="text-xs px-2.5 py-1 rounded-lg bg-slate-50 dark:bg-slate-800 text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700 font-medium">
        {tag}
      </span>
    ))}
  </div>
  {link && (
    <a href={link} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-sm font-semibold text-(--color-primary) hover:underline">
      View Project <span class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
    </a>
  )}
</div>
