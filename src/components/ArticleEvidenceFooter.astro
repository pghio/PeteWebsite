---
import { PROFILE, RESEARCH } from '../data/profile';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const study = RESEARCH.find((item) => new URL(item.url).pathname === currentPath);
---

<aside class="mt-12 space-y-6" aria-label="Evidence and author information">
  {study && (
    <div class="p-6 rounded-2xl bg-slate-50 dark:bg-[#141b2d] border border-slate-200 dark:border-slate-800">
      <p class="text-xs font-semibold text-(--color-primary) tracking-widest uppercase mb-2">Research record · {study.published} snapshot</p>
      <h2 class="text-xl font-bold mb-3">Inspect the method, not just the conclusion</h2>
      <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-4">{study.method}</p>
      <details class="text-sm text-slate-500 dark:text-slate-400 mb-5">
        <summary class="font-semibold text-slate-900 dark:text-white cursor-pointer">Limitations</summary>
        <ul class="list-disc pl-5 mt-3 space-y-2">
          {study.limitations.map(item => <li>{item}</li>)}
        </ul>
      </details>
      <a href={study.repository} target="_blank" rel="noopener" data-profile-cta="research_repo" data-analytics-placement="article_evidence" class="font-semibold text-(--color-primary) hover:underline">View the public methods repository &rarr;</a>
    </div>
  )}

  <div class="p-6 rounded-2xl border border-blue-200 dark:border-blue-900 bg-blue-50/70 dark:bg-blue-950/20">
    <p class="text-xs font-semibold text-(--color-primary) tracking-widest uppercase mb-2">About Pete Ghiorse</p>
    <p class="font-bold text-slate-900 dark:text-white mb-2">{PROFILE.oneLine}</p>
    <p class="text-sm text-slate-500 dark:text-slate-400 mb-5">AI assists with research, red-teaming, implementation, and editing. Pete owns the thesis, source selection, evaluation design, factual claims, and final editorial judgment.</p>
    <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm font-semibold">
      <a href="/projects" data-profile-cta="selected_work" data-analytics-placement="article_author" class="text-(--color-primary) hover:underline">Selected work &rarr;</a>
      <a href="/resume.pdf" data-profile-cta="resume_download" data-analytics-placement="article_author" class="text-(--color-primary) hover:underline">Résumé &rarr;</a>
      <a href="/contact" data-profile-cta="contact" data-analytics-placement="article_author" class="text-(--color-primary) hover:underline">Contact &rarr;</a>
      <a href="https://peterghiorse.substack.com/subscribe?utm_source=peterghiorse.com&utm_medium=website&utm_campaign=content_distribution&utm_content=article_author_chatgpete" target="_blank" rel="noopener" data-newsletter-cta data-analytics-placement="article_author" class="text-(--color-primary) hover:underline">ChatGPeTe &rarr;</a>
    </div>
  </div>
</aside>
