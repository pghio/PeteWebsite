---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROFILE } from '../data/profile';

const links = [
  { name: 'Email', mark: '@', desc: 'Best for a substantive question or collaboration', href: PROFILE.links.email },
  { name: 'LinkedIn', mark: 'in', desc: 'Professional profile and current posts', href: PROFILE.links.linkedin },
  { name: 'GitHub', mark: '</>', desc: 'Repositories, methods, and code', href: PROFILE.links.github },
  { name: 'Honeydew', mark: 'H', desc: 'The production agent I am building', href: PROFILE.links.honeydew },
  { name: PROFILE.publication.name, mark: 'C', desc: 'Research editions and essays', href: 'https://peterghiorse.substack.com/subscribe?utm_source=peterghiorse.com&utm_medium=website&utm_campaign=content_distribution&utm_content=contact_chatgpete', newsletter: true },
];
---

<BaseLayout
  title="Contact"
  description="Contact Pete Ghiorse about AI product leadership, production agents, model evaluation, or published research."
  ogImage="/images/profile/pete-ghiorse-profile-card.png"
  ogImageAlt="Contact Pete Ghiorse about AI product leadership"
>
  <section class="max-w-3xl mx-auto px-6 py-16 md:py-24">
    <p class="text-(--color-primary) font-semibold text-sm tracking-widest uppercase mb-4 animate-fade-up">Contact</p>
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4 animate-fade-up stagger-1">
      Let’s talk about <span class="gradient-text">the work</span>
    </h1>
    <p class="text-slate-500 dark:text-slate-400 mb-4 max-w-2xl text-lg animate-fade-up stagger-2">
      Questions about production agents, model evaluation, AI product work, or something I published are welcome.
    </p>
    <p class="text-sm text-slate-500 dark:text-slate-400 mb-12 animate-fade-up stagger-2">
      New York City
    </p>

    <div class="grid sm:grid-cols-2 gap-5 animate-fade-up stagger-3">
      {links.map(link => {
        const isEmail = link.href.startsWith('mailto:');
        return (
          <a
            href={link.href}
            target={isEmail ? undefined : '_blank'}
            rel={isEmail ? undefined : 'noopener'}
            data-newsletter-cta={link.newsletter ? true : undefined}
            data-newsletter-impression={link.newsletter ? true : undefined}
            data-analytics-placement="contact"
            data-profile-cta={link.name.toLowerCase()}
            data-contact-method={link.name.toLowerCase()}
            class="card-hover flex items-center gap-4 p-6 border border-slate-200 dark:border-slate-800 rounded-2xl group bg-white dark:bg-[#141b2d]"
          >
            <div class="w-12 h-12 rounded-xl bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center text-(--color-primary) font-bold group-hover:bg-blue-100 dark:group-hover:bg-blue-900/30 transition-colors shrink-0">
              {link.mark}
            </div>
            <div>
              <p class="font-bold group-hover:text-(--color-primary) transition-colors">{link.name}</p>
              <p class="text-sm text-slate-500 dark:text-slate-400">{link.desc}</p>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
