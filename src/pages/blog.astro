---
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = [
  {
    title: "Monsters of the Mind(.md)",
    url: "/blog/monsters-of-the-mind",
    description: "We taught a generation to mistake disruption to the jobs they wanted for the disappearance of work itself. The map is changing—and the technology redrawing it may be the best tool we have for learning the next route.",
    category: "Essay",
    isNew: true,
  },
  {
    title: "Falls the Shadow",
    url: "/blog/falls-the-shadow",
    description: "In 2016 the godfather of AI said to stop training radiologists. A decade later their pay hit records. The same forecast error is now being made about writing. On the two halves of every job, the vagueness spiral, and a falsifiable bet on the English major.",
    category: "Essay",
  },
  {
    title: "We Gave Six LLMs a Family to Run. None Were Reckless. The Cheap Ones Still Broke.",
    url: "/blog/llms-knowing-when-to-stop",
    description: "A restraint study on six frontier models, measured against the act/ask/confirm policy that ships inside our family assistant. 227 scenarios, labeled by a panel of three rival models. Over-action was rare, over-caution was everywhere, and the cheaper models lost a fifth of their accuracy the moment someone typed like a real person.",
    category: "Research",
    isNew: true,
  },
  {
    title: "In What Furnace",
    url: "/blog/in-what-furnace",
    description: "AI keeps getting sold as a way to remove friction. There are two kinds, and only one is worth removing. An essay on toil, the work that builds you, and aiming your impatience at the right thing.",
    category: "Essay",
  },
  {
    title: "1,147 Pages, One Person: Inside the SEO Engine That Grades Its Own Work",
    url: "/blog/seo-engine-grades-its-own-work",
    description: "My site's sitemap lists 1,147 pages. I hand-wrote about eighty. The system behind the rest: a writer under scar-tissue rules, a second AI that scores every page for quality, spam, and PII — and the one wire I found missing while fact-checking this post.",
    category: "Engineering",
  },
  {
    title: "$500,000 vs. $2,500: I Built Two Things Five Years Apart",
    url: "/blog/ai-mom-and-pop-software-era",
    description: "The last company I cofounded spent half a million dollars to ship its product. Honeydew has cost around $2,500. Same founder, five years apart—and a 200× change in who gets to build software.",
    category: "Essay",
  },
  {
    title: "We Asked 8 LLMs to Run Our Family's Life. Three Tried to Book a Vacation.",
    url: "/blog/llm-benchmark-stop-defaulting-to-the-frontier",
    description: "We tested 8 LLMs against Honeydew's production family assistant — GPT-4o-mini, Gemini Flash, DeepSeek V3, Claude Haiku, GPT-4.1, Claude Sonnet, GPT-5.4, Claude Opus. 2,800 API calls, five weird findings, and one practitioner tip that'll save you a debugging session.",
    category: "Research",
  },
  {
    title: "Do LLMs Actually Cite Your Startup? An Empirical Analysis of LLM Discoverability Infrastructure",
    url: "/blog/llm-discoverability-research",
    description: "We built an LLM discoverability stack and measured what happened. 13 verified LLM sessions, 3 platforms citing us, and hard data on what works. Full methodology and results.",
    category: "Research",
  },
  {
    title: "How We Get Cited by ChatGPT, Claude & Perplexity Without Ads",
    url: "https://gethoneydew.app/blog/how-we-get-cited-by-chatgpt-claude-perplexity-without-ads",
    description: "A deep dive into LLM discoverability and how we built a citation strategy for Honeydew.",
    category: "AI Strategy",
  },
  {
    title: "Building a Multimodal AI Family Assistant",
    url: "https://gethoneydew.app/blog/building-multimodal-ai-family-assistant-voice-text-photo",
    description: "The architecture behind Honeydew's voice, text, and photo input pipeline.",
    category: "Engineering",
  },
  {
    title: "What I Learned Building an AI Agent That Manages a Family's Life",
    url: "https://gethoneydew.app/blog/what-i-learned-building-ai-agent-family-life",
    description: "Lessons from building a 60+ tool agentic system that real families depend on daily.",
    category: "Product",
  },
];
---

<BaseLayout title="Blog" description="Essays and field reports on what AI actually changes—at work, at home, and inside the products we trust.">
  <section class="max-w-3xl mx-auto px-6 py-16 md:py-24">
    <p class="text-(--color-primary) font-semibold text-sm tracking-widest uppercase mb-4 animate-fade-up">Blog</p>
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4 animate-fade-up stagger-1">
      Writing & <span class="gradient-text">thinking</span>
    </h1>
    <p class="text-slate-500 dark:text-slate-400 mb-12 text-lg animate-fade-up stagger-2">
      Essays and field reports on what AI actually changes—at work, at home, and inside the products we trust.
    </p>

    <div class="mb-12 p-6 rounded-2xl bg-slate-50 dark:bg-[#141b2d] border border-slate-200 dark:border-slate-800 animate-fade-up stagger-3 flex flex-col sm:flex-row sm:items-center justify-between gap-5">
      <div>
        <p class="font-bold text-slate-900 dark:text-white">Follow the writing on Substack.</p>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">New essays by email, plus shorter notes between them.</p>
      </div>
      <a href="https://peterghiorse.substack.com/subscribe?utm_source=peterghiorse.com&utm_medium=website&utm_campaign=newsletter_growth&utm_content=blog_intro" target="_blank" rel="noopener" data-newsletter-cta data-newsletter-impression data-analytics-placement="blog_intro" class="shrink-0 inline-flex justify-center px-5 py-2.5 rounded-xl bg-(--color-primary) text-white font-semibold hover:bg-(--color-primary-dark) transition-colors">
        Subscribe
      </a>
    </div>

    <div class="space-y-5 animate-fade-up stagger-4">
      {articles.map(article => (
        <a
          href={article.url}
          target={article.url.startsWith('/') ? '_self' : '_blank'}
          rel={article.url.startsWith('/') ? undefined : 'noopener'}
          class="card-hover block p-6 border border-slate-200 dark:border-slate-800 rounded-2xl group bg-white dark:bg-[#141b2d]"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <span class="text-xs font-semibold text-(--color-primary) bg-blue-50 dark:bg-blue-900/30 px-2.5 py-1 rounded-full mb-3 inline-block">
                {article.category}
              </span>
              <h2 class="text-lg font-bold group-hover:text-(--color-primary) transition-colors mb-2">
                {article.title}
              </h2>
              <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed">{article.description}</p>
            </div>
            <span class="text-slate-400 text-lg shrink-0 mt-8 transition-transform group-hover:translate-x-1 group-hover:text-(--color-primary)">&rarr;</span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12 p-7 rounded-2xl bg-slate-50 dark:bg-[#141b2d] border border-slate-200 dark:border-slate-800 text-center">
      <p class="font-bold text-slate-900 dark:text-white mb-2">Read the next one here—or have it sent to you.</p>
      <p class="text-slate-500 dark:text-slate-400 text-sm mb-5">
        I publish the product-specific work on the <a href="https://gethoneydew.app/blog" target="_blank" rel="noopener" class="text-(--color-primary) font-semibold hover:underline">Honeydew blog</a> too. Substack is the easiest way to get everything I write.
      </p>
      <a href="https://peterghiorse.substack.com/subscribe?utm_source=peterghiorse.com&utm_medium=website&utm_campaign=newsletter_growth&utm_content=blog_footer" target="_blank" rel="noopener" data-newsletter-cta data-newsletter-impression data-analytics-placement="blog_footer" class="inline-flex px-5 py-2.5 rounded-xl border border-(--color-primary) text-(--color-primary) font-semibold hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors">
        Follow on Substack
      </a>
    </div>
  </section>
</BaseLayout>
