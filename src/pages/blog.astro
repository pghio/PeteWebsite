---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROFILE } from '../data/profile';

const articles = [
  {
    title: "If a Data Center Comes to Town, Your Electric Bill Should Go Down",
    url: "/blog/if-a-data-center-comes-to-town",
    description: "America should build the factories of the AI economy. But the companies that profit from them should bring new power, pay every cost they create, and leave the people living beside them with a visible share of the upside.",
    category: "Essay",
    isNew: true,
  },
  {
    title: "Monsters of the Mind",
    url: "/blog/monsters-of-the-mind",
    description: "We taught a generation to mistake disruption to the jobs they wanted for the disappearance of work itself. The map is changing—and the technology redrawing it may also help us learn the next route.",
    category: "Essay",
    isNew: true,
  },
  {
    title: "Falls the Shadow",
    url: "/blog/falls-the-shadow",
    description: "In 2016 the godfather of AI said to stop training radiologists. A decade later their pay had climbed and employers reported shortages. This essay asks whether the same forecast error is now being made about writing—through the two halves of every job, the vagueness spiral, and a falsifiable bet on the English major.",
    category: "Essay",
  },
  {
    title: "We Gave Six LLMs a Family to Run. Most Hesitated. One Crossed the Safety Line.",
    url: "/blog/llms-knowing-when-to-stop",
    description: "A restraint study on six production-priced models measured against the act/ask/confirm policy inside our family assistant. Over-action was rare overall, but DeepSeek violated 21% of repeated guard-case trials spanning 11 of 35 destructive scenarios. Robustness on messy input varied sharply by model.",
    category: "Research",
    isNew: true,
  },
  {
    title: "In What Furnace",
    url: "/blog/in-what-furnace",
    description: "AI keeps getting sold as a way to remove friction. There are two kinds, and only one is worth removing. An essay on toil, the work that builds you, and aiming your impatience at the right thing.",
    category: "Essay",
  },
  {
    title: "1,147 Pages, One Person: Inside the SEO Engine That Grades Its Own Work",
    url: "/blog/seo-engine-grades-its-own-work",
    description: "My site's sitemap listed 1,147 pages. I hand-wrote about eighty. A breakdown of the generator, the incomplete review and ranking controls around it, and the missing wire I found while fact-checking this post.",
    category: "Engineering",
  },
  {
    title: "$500,000 vs. $2,500: I Built Two Things Five Years Apart",
    url: "/blog/ai-mom-and-pop-software-era",
    description: "GiveTide spent more than $500,000 from 2017 through 2022. Honeydew's cash spend from its 2025 start through this post's May 2026 snapshot was about $2,500, excluding unpaid founder labor. The comparison is imperfect; the change in what one person can build is still real.",
    category: "Essay",
  },
  {
    title: "We Asked 8 LLMs to Run Our Family's Life. Two Tried to Book a Vacation.",
    url: "/blog/llm-benchmark-stop-defaulting-to-the-frontier",
    description: "We tested 8 LLMs against Honeydew's production family-assistant prompt across 2,800 calls. This April 2026 field test is preserved with corrections from a larger June study on messy-input robustness and duplicate handling.",
    category: "Research",
  },
  {
    title: "Do LLMs Actually Cite Your Startup? A 90-Day Field Note",
    url: "/blog/llm-discoverability-research",
    description: "What 13 GA4-attributed sessions, 29 custom referrer events, one citation in ten Perplexity queries, and three web-search appearances can—and cannot—tell an early-stage startup about LLM discovery.",
    category: "Research",
  },
  {
    title: "How We Get Cited by ChatGPT, Claude & Perplexity Without Ads",
    url: "https://gethoneydew.app/blog/how-we-get-cited-by-chatgpt-claude-perplexity-without-ads",
    description: "A deep dive into LLM discoverability and how we built a citation strategy for Honeydew.",
    category: "AI Strategy",
  },
  {
    title: "Building a Multimodal AI Family Assistant",
    url: "https://gethoneydew.app/blog/building-multimodal-ai-family-assistant-voice-text-photo",
    description: "The architecture behind Honeydew's voice, text, and photo input pipeline.",
    category: "Engineering",
  },
  {
    title: "What I Learned Building an AI Agent That Manages a Family's Life",
    url: "https://gethoneydew.app/blog/what-i-learned-building-ai-agent-family-life",
    description: "Lessons from building a tool-using agent that has to interpret real family requests without overreaching.",
    category: "Product",
  },
];
---

<BaseLayout title="Research & Essays" description="Production AI research and essays by Pete Ghiorse on product judgment, agent behavior, and what the evidence changes.">
  <section class="max-w-3xl mx-auto px-6 py-16 md:py-24">
    <p class="text-(--color-primary) font-semibold text-sm tracking-widest uppercase mb-4 animate-fade-up">Research and essays</p>
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4 animate-fade-up stagger-1">
      Evidence first. <span class="gradient-text">Essays when earned.</span>
    </h1>
    <p class="text-slate-500 dark:text-slate-400 mb-12 text-lg animate-fade-up stagger-2">
      The website holds the complete canonical work: production case studies, methods, limitations, corrections, and essays that have survived a harder edit.
    </p>

    <div class="mb-12 p-6 rounded-2xl bg-slate-50 dark:bg-[#141b2d] border border-slate-200 dark:border-slate-800 animate-fade-up stagger-3 flex flex-col sm:flex-row sm:items-center justify-between gap-5">
      <div>
        <p class="font-bold text-slate-900 dark:text-white">{PROFILE.publication.name}</p>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">{PROFILE.publication.description}</p>
      </div>
      <a href="https://peterghiorse.substack.com/subscribe?utm_source=peterghiorse.com&utm_medium=website&utm_campaign=content_distribution&utm_content=blog_intro_chatgpete" target="_blank" rel="noopener" data-newsletter-cta data-newsletter-impression data-analytics-placement="blog_intro_chatgpete" class="shrink-0 inline-flex justify-center px-5 py-2.5 rounded-xl bg-(--color-primary) text-white font-semibold hover:bg-(--color-primary-dark) transition-colors">
        Subscribe to ChatGPeTe
      </a>
    </div>

    <div class="space-y-5 animate-fade-up stagger-4">
      {articles.map(article => (
        <a
          href={article.url}
          target={article.url.startsWith('/') ? '_self' : '_blank'}
          rel={article.url.startsWith('/') ? undefined : 'noopener'}
          class="card-hover block p-6 border border-slate-200 dark:border-slate-800 rounded-2xl group bg-white dark:bg-[#141b2d]"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <span class="text-xs font-semibold text-(--color-primary) bg-blue-50 dark:bg-blue-900/30 px-2.5 py-1 rounded-full mb-3 inline-block">
                {article.category}
              </span>
              <h2 class="text-lg font-bold group-hover:text-(--color-primary) transition-colors mb-2">
                {article.title}
              </h2>
              <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed">{article.description}</p>
            </div>
            <span class="text-slate-400 text-lg shrink-0 mt-8 transition-transform group-hover:translate-x-1 group-hover:text-(--color-primary)">&rarr;</span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12 p-7 rounded-2xl bg-slate-50 dark:bg-[#141b2d] border border-slate-200 dark:border-slate-800 text-center">
      <p class="font-bold text-slate-900 dark:text-white mb-2">Read the full work here—or get the shorter edition.</p>
      <p class="text-slate-500 dark:text-slate-400 text-sm mb-5">
        The website is canonical. ChatGPeTe is the email edition; product-specific operating notes may also appear on the <a href="https://gethoneydew.app/blog" target="_blank" rel="noopener" class="text-(--color-primary) font-semibold hover:underline">Honeydew blog</a>.
      </p>
      <a href="https://peterghiorse.substack.com/subscribe?utm_source=peterghiorse.com&utm_medium=website&utm_campaign=content_distribution&utm_content=blog_footer_chatgpete" target="_blank" rel="noopener" data-newsletter-cta data-newsletter-impression data-analytics-placement="blog_footer_chatgpete" class="inline-flex px-5 py-2.5 rounded-xl border border-(--color-primary) text-(--color-primary) font-semibold hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors">
        Follow ChatGPeTe
      </a>
    </div>
  </section>
</BaseLayout>
