---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import { PROFILE, RESEARCH } from '../data/profile';

const restraint = RESEARCH.find((study) => study.id === 'restraint-study-2026-06-24');
const benchmark = RESEARCH.find((study) => study.id === 'production-benchmark-2026-04-15');
if (!restraint || !benchmark) throw new Error('Required research records are missing');
---

<BaseLayout
  title="Resume"
  description="Pete Ghiorse is a Group Product Manager for AI/ML, founder, and hands-on builder focused on production agents, model evaluation, and 0-to-1 products."
  ogImage="/images/profile/pete-ghiorse-profile-card.png"
  ogImageAlt="Résumé for Pete Ghiorse, AI/ML product leader"
>
  <section class="max-w-3xl mx-auto px-6 py-16 md:py-24">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4 animate-fade-up">
      <p class="text-(--color-primary) font-semibold text-sm tracking-widest uppercase">Recruiter snapshot</p>
      <a href="/resume.pdf" data-profile-cta="resume_download" data-analytics-placement="resume_header" class="text-sm font-semibold text-(--color-primary) hover:underline">Download two-page PDF &rarr;</a>
    </div>
    <h1 class="text-4xl md:text-5xl font-extrabold mb-10 animate-fade-up stagger-1">
      AI product leadership with <span class="gradient-text">hands-on evidence</span>
    </h1>

    <div class="mb-14 p-6 rounded-2xl border border-blue-200 dark:border-blue-900 bg-blue-50/70 dark:bg-blue-950/20 animate-fade-up stagger-2">
      <p class="text-xl text-slate-700 dark:text-slate-200 leading-relaxed mb-4">{PROFILE.oneLine}</p>
      <p class="text-sm text-slate-500 dark:text-slate-400 mb-5">New York City–based · Open to regular Bay Area travel for the right role</p>
      <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm font-semibold">
        <a href={PROFILE.links.email} data-profile-cta="email" data-analytics-placement="resume_intro" class="text-(--color-primary) hover:underline">pmghiorse@gmail.com</a>
        <a href={PROFILE.links.linkedin} target="_blank" rel="noopener" data-profile-cta="linkedin" data-analytics-placement="resume_intro" class="text-(--color-primary) hover:underline">LinkedIn</a>
        <a href={PROFILE.links.github} target="_blank" rel="noopener" data-profile-cta="github" data-analytics-placement="resume_intro" class="text-(--color-primary) hover:underline">GitHub</a>
        <a href="/projects" data-profile-cta="selected_work" data-analytics-placement="resume_intro" class="text-(--color-primary) hover:underline">Selected work</a>
      </div>
    </div>

    <h2 class="text-lg font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-8 animate-fade-up stagger-2">Experience</h2>
    <div class="mb-16 animate-fade-up stagger-3">
      <ExperienceItem
        company="Capital One"
        role="Group Product Manager, AI/ML"
        period="2022 – Present"
        description="Leading product direction for ML-powered spend controls and fraud detection."
        highlights={[
          'Own product strategy and roadmap decisions for AI/ML-dependent experiences.',
          'Lead cross-functional work across engineering, data science, design, and risk partners.',
          'Translate model uncertainty and operating constraints into product boundaries and success criteria.',
        ]}
      />
      <ExperienceItem
        company="Honeydew"
        role="Founder"
        period="2025 – Present"
        description="Building a multimodal family-coordination agent and using it as a production lab for model behavior, evaluation, and trust."
        highlights={[
          'Own discovery, product strategy, implementation, instrumentation, evaluation, and distribution.',
          'Turn voice, text, and photo requests into shared household plans through a tool-using agent.',
          `Designed a ${restraint.numbers.scenarios}-scenario restraint study spanning ${restraint.numbers.calls.toLocaleString()} model calls.`,
        ]}
      />
      <ExperienceItem
        company="GiveTide"
        role="Co-Founder"
        period="2017 – 2022"
        description="Co-founded and ran a charitable-giving fintech product for five years before its acquisition in 2022."
        highlights={[
          'Led product from concept through launch, operation, and acquisition.',
          'Worked across product, customer discovery, full-stack implementation, and company building.',
          'Exited through an acquisition in 2022.',
        ]}
      />
    </div>

    <h2 class="text-lg font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-8">Selected evidence</h2>
    <div class="grid sm:grid-cols-2 gap-5 mb-16">
      <a href="/blog/llms-knowing-when-to-stop" class="card-hover p-5 rounded-xl bg-slate-50 dark:bg-[#141b2d] border border-slate-200 dark:border-slate-800">
        <h3 class="font-bold mb-2">Agent restraint evaluation</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">{restraint.numbers.scenarios} scenarios, {restraint.numbers.models} models, {restraint.numbers.calls.toLocaleString()} calls, methods and limitations published.</p>
      </a>
      <a href="/blog/llm-benchmark-stop-defaulting-to-the-frontier" class="card-hover p-5 rounded-xl bg-slate-50 dark:bg-[#141b2d] border border-slate-200 dark:border-slate-800">
        <h3 class="font-bold mb-2">Production model benchmark</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">{benchmark.numbers.models} models, {benchmark.numbers.scenarios} scenarios, {benchmark.numbers.calls.toLocaleString()} calls, with prompt-coupling caveats retained.</p>
      </a>
    </div>

    <h2 class="text-lg font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-8">Capabilities</h2>
    <div class="grid sm:grid-cols-2 gap-5 mb-16">
      {PROFILE.focusAreas.map(area => (
        <div class="p-5 rounded-xl bg-slate-50 dark:bg-[#141b2d] border border-slate-200 dark:border-slate-800">
          <h3 class="font-bold mb-2">{area.title}</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">{area.description}</p>
        </div>
      ))}
    </div>

    <h2 class="text-lg font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-8">Education</h2>
    <div class="mb-16">
      <ExperienceItem company={`${PROFILE.education.institution} — ${PROFILE.education.school}`} role={PROFILE.education.degree} period={PROFILE.education.honor} description="" />
    </div>

    <div class="p-6 rounded-2xl border border-slate-200 dark:border-slate-800 text-center">
      <p class="font-bold mb-2">Target roles</p>
      <p class="text-sm text-slate-500 dark:text-slate-400 mb-5">{PROFILE.targetRoles.join(' · ')}</p>
      <a href="/contact" data-profile-cta="recruiter_contact" data-analytics-placement="resume_footer" class="font-semibold text-(--color-primary) hover:underline">Start a conversation &rarr;</a>
    </div>
  </section>
</BaseLayout>
