---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
---

<BaseLayout title="Home">
  <Hero />

  <section class="max-w-5xl mx-auto px-6 pb-24">
    <div class="grid md:grid-cols-3 gap-5 mb-20">
      <div class="card-hover p-6 rounded-2xl bg-slate-50 dark:bg-[#141b2d] border border-slate-200 dark:border-slate-800 animate-fade-up stagger-3">
        <p class="text-4xl font-extrabold gradient-text mb-2">4+</p>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">Years leading AI/ML product at Capital One</p>
      </div>
      <div class="card-hover p-6 rounded-2xl bg-slate-50 dark:bg-[#141b2d] border border-slate-200 dark:border-slate-800 animate-fade-up stagger-4">
        <p class="text-4xl font-extrabold gradient-text mb-2">1</p>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">Successful startup exit (GiveTide, acquired 2022)</p>
      </div>
      <div class="card-hover p-6 rounded-2xl bg-slate-50 dark:bg-[#141b2d] border border-slate-200 dark:border-slate-800 animate-fade-up stagger-5">
        <p class="text-4xl font-extrabold gradient-text mb-2">60+</p>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">AI tools orchestrated in Honeydew's agent pipeline</p>
      </div>
    </div>

    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold">Featured Projects</h2>
      <a href="/projects" class="text-sm font-semibold text-(--color-primary) hover:underline inline-flex items-center gap-1">View all <span>&rarr;</span></a>
    </div>
    <div class="grid md:grid-cols-2 gap-5 mb-20">
      <ProjectCard title="Honeydew" description="An AI assistant that turns voice notes, texts, and photos into shared calendars, lists, and plans for a family. Dew routes each request through a catalog of 60+ tools." tags={["React", "TypeScript", "Node.js", "OpenAI", "WebSockets"]} link="https://gethoneydew.app" status="Active" />
      <ProjectCard title="GiveTide" description="The charitable-giving product I co-founded, ran for five years, and sold in 2022. It was also the expensive lesson behind my essay on how radically software economics changed." tags={["Fintech", "Startup", "Acquired"]} status="Acquired 2022" />
    </div>

    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold">Recent Writing</h2>
      <a href="/blog" class="text-sm font-semibold text-(--color-primary) hover:underline inline-flex items-center gap-1">View all <span>&rarr;</span></a>
    </div>
    <div class="space-y-4">
      <a href="/blog/monsters-of-the-mind" class="card-hover flex items-center justify-between p-5 border border-slate-200 dark:border-slate-800 rounded-2xl group bg-white dark:bg-[#141b2d]">
        <div>
          <h3 class="font-semibold group-hover:text-(--color-primary) transition-colors">Monsters of the Mind</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">On AI job forecasts, status maps, and learning the next route</p>
        </div>
        <span class="text-slate-400 text-sm shrink-0 ml-4 transition-transform group-hover:translate-x-0.5 group-hover:text-(--color-primary)">&rarr;</span>
      </a>
      <a href="/blog/falls-the-shadow" class="card-hover flex items-center justify-between p-5 border border-slate-200 dark:border-slate-800 rounded-2xl group bg-white dark:bg-[#141b2d]">
        <div>
          <h3 class="font-semibold group-hover:text-(--color-primary) transition-colors">Falls the Shadow</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Why abundant intelligence makes intention more valuable</p>
        </div>
        <span class="text-slate-400 text-sm shrink-0 ml-4 transition-transform group-hover:translate-x-0.5 group-hover:text-(--color-primary)">&rarr;</span>
      </a>
      <a href="/blog/in-what-furnace" class="card-hover flex items-center justify-between p-5 border border-slate-200 dark:border-slate-800 rounded-2xl group bg-white dark:bg-[#141b2d]">
        <div>
          <h3 class="font-semibold group-hover:text-(--color-primary) transition-colors">In What Furnace</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">The friction worth removing—and the friction worth keeping</p>
        </div>
        <span class="text-slate-400 text-sm shrink-0 ml-4 transition-transform group-hover:translate-x-0.5 group-hover:text-(--color-primary)">&rarr;</span>
      </a>
    </div>

    <div class="mt-12 p-8 rounded-2xl bg-slate-50 dark:bg-[#141b2d] border border-slate-200 dark:border-slate-800 text-center">
      <p class="text-xs font-semibold text-(--color-primary) tracking-widest uppercase mb-3">The next essay</p>
      <h2 class="text-2xl font-bold mb-3">Get it when I publish it.</h2>
      <p class="text-slate-500 dark:text-slate-400 max-w-xl mx-auto mb-5">Essays and field reports on AI, product judgment, and the work the machine cannot choose for us.</p>
      <a href="https://peterghiorse.substack.com/subscribe?utm_source=peterghiorse.com&utm_medium=website&utm_campaign=newsletter_growth&utm_content=homepage_writing" target="_blank" rel="noopener" data-newsletter-cta data-newsletter-impression data-analytics-placement="homepage_writing" class="inline-flex px-6 py-3 rounded-xl bg-(--color-primary) text-white font-semibold hover:bg-(--color-primary-dark) transition-colors">
        Subscribe on Substack
      </a>
    </div>
  </section>
</BaseLayout>
