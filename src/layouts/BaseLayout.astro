---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Pete Ghiorse — AI Product Leader, Founder, Builder" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://peterghiorse.com');
const ogImage = 'https://peterghiorse.com/images/research/hero-llm-discoverability.png';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Pete Ghiorse",
  "url": "https://peterghiorse.com",
  "jobTitle": "Senior Product Manager, AI/ML",
  "worksFor": {
    "@type": "Organization",
    "name": "Capital One"
  },
  "alumniOf": {
    "@type": "CollegeOrUniversity",
    "name": "University of Richmond"
  },
  "knowsAbout": ["AI Product Management", "Machine Learning", "Agentic Systems", "LLM Discoverability", "Startup Founding"],
  "sameAs": [
    "https://linkedin.com/in/peteghiorse",
    "https://github.com/pghio",
    "https://gethoneydew.app"
  ]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Pete Ghiorse",
  "url": "https://peterghiorse.com",
  "description": "AI product leader, founder of Honeydew, and builder of products at the intersection of AI and real-world impact.",
  "author": { "@type": "Person", "name": "Pete Ghiorse" }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | Pete Ghiorse`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Pete Ghiorse`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="author" content="Pete Ghiorse" />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Pete Ghiorse</title>
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script is:inline>
      if (localStorage.getItem('theme') === 'dark' ||
        (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="bg-white dark:bg-[#0a0f1a] text-slate-900 dark:text-slate-100 min-h-screen flex flex-col transition-colors duration-200">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
