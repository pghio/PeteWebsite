---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { GA_MEASUREMENT_ID } from '../config/analytics';
import { PROFILE, PROFILE_SOURCE, RESEARCH } from '../data/profile';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Pete Ghiorse leads AI/ML products, builds production agents, and publishes rigorous evaluations of how they behave.',
  ogImage = '/images/profile/pete-ghiorse-profile-card.png',
  ogImageAlt = 'Pete Ghiorse, AI/ML product leader focused on production agents and evaluation',
  noindex = false,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://peterghiorse.com');
const socialTitle = title === 'Home'
  ? 'Pete Ghiorse | AI/ML Product Leader and Agent Builder'
  : `${title} | Pete Ghiorse`;
const socialImageURL = new URL(ogImage, 'https://peterghiorse.com');
const analyticsEnabled = Boolean(GA_MEASUREMENT_ID);

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${PROFILE.links.website}/#person`,
  "name": PROFILE.name,
  "alternateName": PROFILE.fullName,
  "url": PROFILE.links.website,
  "description": PROFILE.oneLine,
  "jobTitle": PROFILE.role,
  "homeLocation": {
    "@type": "Place",
    "name": PROFILE.location.display,
  },
  "worksFor": {
    "@type": "Organization",
    "name": "Capital One"
  },
  "alumniOf": {
    "@type": "CollegeOrUniversity",
    "name": "University of Richmond"
  },
  "knowsAbout": PROFILE.targetDomains,
  "subjectOf": RESEARCH.map((study) => ({
    "@type": "Article",
    "name": study.title,
    "url": study.url,
  })),
  "sameAs": [
    PROFILE.links.linkedin,
    PROFILE.links.github,
    PROFILE.links.substack,
    PROFILE.links.honeydew,
  ]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${PROFILE.links.website}/#website`,
  "name": PROFILE.name,
  "url": PROFILE.links.website,
  "description": PROFILE.oneLine,
  "inLanguage": "en-US",
  "author": { "@id": `${PROFILE.links.website}/#person` },
};

const profilePageSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": `${canonicalURL.href}#profile-page`,
  "url": canonicalURL.href,
  "name": socialTitle,
  "description": description,
  "dateModified": PROFILE_SOURCE.lastReviewed,
  "mainEntity": { "@id": `${PROFILE.links.website}/#person` },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="Pete Ghiorse" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={socialImageURL.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL.href} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <meta name="author" content="Pete Ghiorse" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" type="application/rss+xml" title="ChatGPeTe — Research and Essays by Pete Ghiorse" href="/rss.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{socialTitle}</title>
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(profilePageSchema)} />
    <Analytics />
    <script is:inline>
      // Default to the bone/navy light look; dark is opt-in via the toggle.
      if (localStorage.getItem('theme') === 'dark') {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="bg-white dark:bg-[#0a0f1a] text-slate-900 dark:text-slate-100 min-h-screen flex flex-col transition-colors duration-200">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    {analyticsEnabled && <CookieConsent />}
  </body>
</html>
