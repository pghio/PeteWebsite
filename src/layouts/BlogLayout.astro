---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  publishDate?: string;
  category?: string;
}

const { frontmatter } = Astro.props;
const title = frontmatter?.title;
const description = frontmatter?.description;
const publishDate = frontmatter?.publishDate;
const category = frontmatter?.category;
const ogImage = frontmatter?.ogImage;
const faq = frontmatter?.faq;
const canonicalURL = new URL(Astro.url.pathname, 'https://peterghiorse.com');

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": publishDate,
  "author": {
    "@type": "Person",
    "name": "Pete Ghiorse",
    "url": "https://peterghiorse.com",
    "jobTitle": "Senior Product Manager, AI/ML",
    "sameAs": ["https://linkedin.com/in/peteghiorse", "https://github.com/pghio"]
  },
  "publisher": {
    "@type": "Person",
    "name": "Pete Ghiorse",
    "url": "https://peterghiorse.com"
  },
  "mainEntityOfPage": canonicalURL.href,
  ...(ogImage ? { "image": `https://peterghiorse.com${ogImage}` } : {}),
  ...(category ? { "articleSection": category } : {})
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://peterghiorse.com" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://peterghiorse.com/blog" },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL.href }
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL.href} />
    {ogImage && <meta property="og:image" content={`https://peterghiorse.com${ogImage}`} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={`https://peterghiorse.com${ogImage}`} />}
    <meta name="author" content="Pete Ghiorse" />
    {publishDate && <meta property="article:published_time" content={publishDate} />}
    {category && <meta property="article:section" content={category} />}
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Pete Ghiorse</title>
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faq && faq.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faq.map((item: { q: string; a: string }) => ({
          "@type": "Question",
          "name": item.q,
          "acceptedAnswer": { "@type": "Answer", "text": item.a }
        }))
      })} />
    )}
    <script is:inline>
      // Default to the bone/navy light look; dark is opt-in via the toggle.
      if (localStorage.getItem('theme') === 'dark') {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="bg-(--color-surface) text-(--color-text) min-h-screen flex flex-col transition-colors duration-200">
    <Header />
    <main class="flex-1">
      <article class="max-w-3xl mx-auto px-6 py-16 md:py-24">
        <div class="mb-10 animate-fade-up">
          <div class="flex items-center gap-3 mb-4">
            {category && (
              <span class="text-xs font-semibold text-(--color-primary) bg-(--color-primary)/10 px-2.5 py-1 rounded-full">
                {category}
              </span>
            )}
            {publishDate && (
              <time class="text-sm text-(--color-text-muted)">{new Date(publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            )}
          </div>
          <h1 class="text-3xl md:text-4xl font-extrabold leading-tight mb-4">{title}</h1>
          {description && <p class="text-(--color-text-muted) text-lg">{description}</p>}
          <div class="flex items-center gap-3 mt-6 pt-6 border-t border-(--color-border)">
            <div class="w-10 h-10 rounded-full bg-(--color-primary)/10 flex items-center justify-center text-(--color-primary) font-bold text-sm">PG</div>
            <div>
              <p class="font-semibold text-sm">Pete Ghiorse</p>
              <p class="text-xs text-(--color-text-muted)">Founder, Honeydew Family AI</p>
            </div>
          </div>
        </div>

        <div class="prose animate-fade-up animate-delay-1">
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
